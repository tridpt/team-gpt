# ── Server ────────────────────────────────────────────────
PORT=4000

# Directory for durable JSON data (users, sessions, conversations, usage).
DATA_DIR=./data

# Secret used to sign/secure things and to seed the first admin.
# Set a long random value in production.
SESSION_TTL_HOURS=168

# Send the session cookie only over HTTPS. Set to true in production when
# TeamGPT runs behind TLS (directly or via a reverse proxy).
COOKIE_SECURE=false

# ── Login brute-force protection ──────────────────────────
# Lock a given IP+email after this many failed attempts within the window.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15

# ── Upstream LLM gateway ──────────────────────────────────
# TeamGPT does not call providers directly. It sends OpenAI-compatible
# requests to the llm-gateway, which holds the real provider keys.
GATEWAY_URL=http://localhost:8080
GATEWAY_API_KEY=demo-key-123

# Default model offered to users (must be known to the gateway).
DEFAULT_MODEL=gpt-4o-mini

# Comma-separated list of models users can pick in the UI.
AVAILABLE_MODELS=gpt-4o-mini,gemini-2.0-flash,mock-gpt

# ── First admin (created on first boot if no users exist) ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

# ── Default per-user daily budgets ────────────────────────
# null/empty = unlimited. Override per user from the admin dashboard.
DEFAULT_DAILY_REQUESTS=200
DEFAULT_DAILY_COST_USD=1.0
